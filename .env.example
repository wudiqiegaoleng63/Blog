# Stage 1 本地 Compose 示例。复制为 .env 后，先替换所有 development-only/change-me 值。
# .env 不是应用内配置加载器；Go config.Load 只读进程环境。Compose 会读取本文件并仅透传
# deploy/compose.yaml 中显式列出的变量；AI/Milvus 变量仍是后续阶段模板。

# -----------------------------------------------------------------------------
# Compose 自身与服务初始化
# -----------------------------------------------------------------------------
BLOG_BACKEND_IMAGE_TAG=stage2
BLOG_FRONTEND_IMAGE_TAG=stage2
PROXY_BIND_ADDRESS=0.0.0.0
PROXY_PORT=8080

# MySQL 服务初始化凭据：MYSQL_PASSWORD 是数据库用户密码，MYSQL_ROOT_PASSWORD 是 root 密码。
# 两者都不是 MYSQL_DSN；Compose 不会自动从这些字段拼接应用 DSN。
MYSQL_DATABASE=blog
MYSQL_USER=blog
MYSQL_PASSWORD=development-only-mysql-password
MYSQL_ROOT_PASSWORD=development-only-mysql-root-password

# Redis 服务密码同时用于 redis-server requirepass 和应用客户端认证。
REDIS_PASSWORD=development-only-redis-password

# deploy/compose.dev.yaml 仅把这些端口发布到 127.0.0.1，不提供热重载。
API_DEBUG_PORT=8081
MYSQL_DEBUG_PORT=3306
REDIS_DEBUG_PORT=6379

# -----------------------------------------------------------------------------
# 当前 Go 应用的重要配置
# -----------------------------------------------------------------------------
APP_NAME=blog
APP_ENV=dev
# Compose 会分别为 api/worker 覆盖该值；直接运行二进制时必须设为 api 或 worker。
APP_SERVICE_MODE=api
# 单个 HTTP 请求的应用级总时长限制。
APP_REQUEST_TIMEOUT=15s

HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=15s
HTTP_MAX_BODY_BYTES=2097152
HTTP_TRUSTED_PROXIES=172.28.0.0/16

# 这是 go-sql-driver/mysql DSN，不是 mysql:// URL；默认连接 Compose 服务 mysql。
# 必须与上面的 MYSQL_USER、MYSQL_PASSWORD、MYSQL_DATABASE 保持一致。
# 若密码或参数含 $、#、空格及 DSN/查询串保留字符，请分别按 .env/Compose 插值规则和
# go-sql-driver/mysql DSN 规则进行引用或转义；不要把未经处理的 secret 粘贴进 DSN。
MYSQL_DSN=blog:development-only-mysql-password@tcp(mysql:3306)/blog?charset=utf8mb4&parseTime=true&loc=UTC
MYSQL_MAX_OPEN_CONNS=25
MYSQL_MAX_IDLE_CONNS=5
MYSQL_CONN_MAX_LIFETIME=30m
MYSQL_CONN_MAX_IDLE_TIME=5m

REDIS_ADDR=redis:6379
REDIS_USERNAME=
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_KEY_PREFIX=blog:dev:v1:

# 仅开发占位，长度超过 32 bytes；部署前必须替换为随机 secret，绝不可用于生产。
# 生产可改用 JWT_SECRET_FILE=/run/secrets/jwt_secret；MYSQL_DSN、REDIS_PASSWORD、
# AI_CHAT_API_KEY、AI_EMBEDDING_API_KEY、MILVUS_PASSWORD 同样支持对应 *_FILE。
JWT_SECRET=development-only-jwt-secret-change-me-32-bytes-minimum
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
AUTH_REFRESH_COOKIE_NAME=blog_rt
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# 默认不允许跨源。启用 credentials 时不要将 origins 设为 *。
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-CSRF-Token,X-Request-ID
CORS_EXPOSED_HEADERS=
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=12h

# Stage 1 认证和评论写入限额；AI 限额保留给 Stage 4。
RATE_REGISTER_PER_MINUTE=5
RATE_LOGIN_PER_MINUTE=10
RATE_REFRESH_PER_MINUTE=30
RATE_COMMENT_PER_MINUTE=10
RATE_AI_PER_MINUTE=10

# Stage 1 MySQL Worker 的轮询、重试预算、stale-lock 时限与批量大小。
JOBS_POLL_INTERVAL=2s
JOBS_MAX_ATTEMPTS=5
JOBS_LOCK_SECONDS=60
JOBS_BATCH_SIZE=10

LOG_LEVEL=debug
LOG_FORMAT=text
# Worker 内部 Prometheus scrape listener；Compose 不发布到宿主机。
METRICS_ADDR=:9090
REQUEST_ID_HEADER=X-Request-ID

# -----------------------------------------------------------------------------
# 阶段 3/4 预留：OpenAI-compatible Chat / Embedding 与 Milvus/RAG
# -----------------------------------------------------------------------------
# 基础栈默认关闭 AI。需要无外网的完整 AI 演示时，使用 make mock-ai-up；
# deploy/compose.mock-ai.yaml 会覆盖以下开关和 Provider 配置，不需要修改本文件。
AI_ENABLED=false
AI_INDEXING_ENABLED=false
AI_RAG_ENABLED=false

# OpenAI-compatible Chat（阶段 4 RAG 问答启用）
AI_CHAT_BASE_URL=https://api.example.invalid/v1
AI_CHAT_API_KEY=later-stage-placeholder-not-a-real-api-key
AI_CHAT_MODEL=later-stage-placeholder-chat-model
AI_CHAT_MAX_TOKENS=1200
AI_CHAT_TIMEOUT=90s
AI_CHAT_STREAM_IDLE_TIMEOUT=45s
AI_CHAT_MAX_RETRIES=2

# OpenAI-compatible Embedding（阶段 3 AI 索引启用）
AI_EMBEDDING_BASE_URL=https://api.example.invalid/v1
AI_EMBEDDING_API_KEY=later-stage-placeholder-not-a-real-api-key
AI_EMBEDDING_MODEL=later-stage-placeholder-embedding-model
AI_EMBEDDING_DIMENSIONS=1536
AI_EMBEDDING_BATCH_SIZE=32
AI_EMBEDDING_TIMEOUT=30s
AI_EMBEDDING_MAX_RETRIES=3

# Milvus 与 RAG 参数（Milvus/索引阶段 3；问答 RAG 阶段 4）
MILVUS_ADDR=http://milvus:19530
MILVUS_COLLECTION_NAME=blog_chunks_v1
MILVUS_COLLECTION_ALIAS=blog_chunks_active
MILVUS_USERNAME=
MILVUS_PASSWORD=
MILVUS_DIAL_TIMEOUT=5s
MILVUS_CONNECT_TIMEOUT=10s
RAG_TOP_K=20
RAG_FINAL_CHUNKS=6
RAG_MAX_CHUNKS_PER_POST=3
RAG_SCORE_THRESHOLD=0.0
RAG_MAX_QUESTION_CHARS=2000
